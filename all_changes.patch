+
+<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
+<script>
+(function () {
+  "use strict";
+
+  // -----------------------------------------------------------------------
+  // Constants
+  // -----------------------------------------------------------------------
+  const canvas = document.getElementById("mixer");
+  const ctx = canvas.getContext("2d");
+  const CX = canvas.width / 2;
+  const CY = canvas.height / 2;
+  const RING_RADIUS = 190;
+  const NODE_RADIUS = 28;
+  const CP_RADIUS = 16;
+  const EPSILON = 400;
+  const ARROW_STEP = 12;
+  const ARROW_FINE_STEP = 3;
+
+  // -----------------------------------------------------------------------
+  // State
+  // -----------------------------------------------------------------------
+  const state = {
+    devices: [],
+    cp: { x: CX, y: CY },
+    isDragging: false,
+    connected: false,
+    wsConnected: false,
+    lastError: null,
+    lastSentVolumes: {},
+    curveType: "inverse-square",
+    mutedDevices: new Set(),
+    groups: {},
+    focusedDeviceIndex: -1,
+  };
+
+  // Audio levels: raw values from server + smoothed display values
+  const audioLevels = {};      // device_id -> raw level (0.0-1.0)
+  const audioLevelsSmooth = {}; // device_id -> smoothed display level
+
+  const statusBar = document.getElementById("statusBar");
+  const ariaLive = document.getElementById("ariaLive");
+
+  // -----------------------------------------------------------------------
+  // WebSocket
+  // -----------------------------------------------------------------------
+  let socket = null;
+  try {
+    socket = io({ transports: ["websocket", "polling"] });
+
+    socket.on("connect", () => {
+      state.wsConnected = true;
+      updateStatus();
+    });
+
+    socket.on("disconnect", () => {
+      state.wsConnected = false;
+      updateStatus();
+    });
+
+    socket.on("devices_updated", (devices) => {
+      const prevIds = state.devices.map(d => d.id).join(",");
+      layoutDevices(devices);
+      state.connected = true;
+      state.lastError = null;
+      updateStatus();
+      // Only re-render panels if the device list changed (avoids losing user state)
+      const newIds = devices.map(d => d.id).join(",");
+      if (prevIds !== newIds) {
+        renderEQPanel();
+        renderGroupDeviceChecklist();
+      }
+    });
+
+    socket.on("groups_updated", (groups) => {
+      state.groups = groups || {};
+      renderGroupList();
+    });
+
+    socket.on("mute_changed", (data) => {
+      if (data.muted) {
+        state.mutedDevices.add(data.device_id);
+      } else {
+        state.mutedDevices.delete(data.device_id);
+      }
+    });
+
+    socket.on("eq_changed", (data) => {
+      const dev = state.devices.find(d => d.id === data.device_id);
+      if (dev) dev.eq = data.eq;
+    });
+
+    socket.on("device_reconnected", (data) => {
+      announce(`Device reconnected, volume restored to ${Math.round(data.restored_volume * 100)}%`);
+    });
+  } catch (e) {
+    // Fallback: no WebSocket support, use HTTP polling
+    console.warn("WebSocket unavailable, falling back to HTTP polling");
+  }
+
+  // -----------------------------------------------------------------------
+  // Accessibility announcements
+  // -----------------------------------------------------------------------
+  function announce(msg) {
+    ariaLive.textContent = msg;
+  }
+
+  // -----------------------------------------------------------------------
+  // Device layout
+  // -----------------------------------------------------------------------
+  function layoutDevices(devices) {
+    const n = devices.length;
+    // Build lookup map from previous devices for O(1) access
+    const prevMap = new Map(state.devices.map(p => [p.id, p]));
+    devices.forEach((d, i) => {
+      const angle = (i * 2 * Math.PI) / n - Math.PI / 2;
+      d.x = CX + RING_RADIUS * Math.cos(angle);
+      d.y = CY + RING_RADIUS * Math.sin(angle);
+      const prev = prevMap.get(d.id);
+      d.displayVol = prev ? prev.displayVol : (d.volume ?? 0);
+      d.targetVol = prev ? prev.targetVol : (d.volume ?? 0);
+      if (d.muted) state.mutedDevices.add(d.id);
+    });
+    state.devices = devices;
+  }
+
+  // -----------------------------------------------------------------------
+  // Device fetching (HTTP fallback)
+  // -----------------------------------------------------------------------
+  async function fetchDevices() {
+    try {
+      const res = await fetch("/api/devices");
+      if (!res.ok) throw new Error(`HTTP ${res.status}`);
+      const devices = await res.json();
+      const prevIds = state.devices.map(d => d.id).join(",");
+      layoutDevices(devices);
+      state.connected = true;
+      state.lastError = null;
+      updateStatus();
+      const newIds = devices.map(d => d.id).join(",");
+      if (prevIds !== newIds) {
+        renderEQPanel();
+        renderGroupDeviceChecklist();
+      }
+    } catch {
+      state.connected = false;
+      state.lastError = "Connection lost \u2014 retrying...";
+      updateStatus();
+    }
+  }
+
+  function updateStatus() {
+    const wsSpan = `<span class="ws-indicator ${state.wsConnected ? 'connected' : 'disconnected'}" id="wsIndicator"></span>`;
+    if (!state.connected) {
+      statusBar.innerHTML = wsSpan + (state.lastError || "Disconnected");
+      statusBar.className = "status-bar error";
+    } else {
+      const n = state.devices.length;
+      const muted = state.mutedDevices.size;
+      let text = n > 0
+        ? `${n} device${n !== 1 ? "s" : ""} connected`
+        : "No speakers detected";
+      if (muted > 0) text += ` \u00b7 ${muted} muted`;
+      text += ` \u00b7 ${state.curveType}`;
+      statusBar.innerHTML = wsSpan + text;
+      statusBar.className = "status-bar";
+    }
+  }
+
+  // -----------------------------------------------------------------------
+  // Crossfade curve functions
+  // -----------------------------------------------------------------------
+  const curves = {
+    "inverse-square": (distSq) => 1 / (distSq + EPSILON),
+    "linear": (distSq) => {
+      const dist = Math.sqrt(distSq);
+      const maxDist = RING_RADIUS * 2;
+      return Math.max(0, 1 - dist / maxDist);
+    },
+    "logarithmic": (distSq) => {
+      const dist = Math.sqrt(distSq);
+      return 1 / (1 + Math.log1p(dist) * 0.5);
+    },
+    "equal-power": (distSq) => {
+      const dist = Math.sqrt(distSq);
+      const maxDist = RING_RADIUS * 2;
+      const ratio = Math.min(1, dist / maxDist);
+      return Math.cos(ratio * Math.PI / 2);
+    },
+  };
+
+  // -----------------------------------------------------------------------
+  // Volume calculation
+  // -----------------------------------------------------------------------
+  function computeVolumes() {
+    if (state.devices.length === 0) return;
+
+    const curveFn = curves[state.curveType] || curves["inverse-square"];
+
+    const weights = state.devices.map(d => {
+      if (state.mutedDevices.has(d.id)) return 0;
+      const dx = state.cp.x - d.x;
+      const dy = state.cp.y - d.y;
+      return curveFn(dx * dx + dy * dy);
+    });
+
+    const maxW = Math.max(...weights);
+
+    // Apply group logic: devices in the same group get the same (max) volume
+    const groupVolumes = {};
+
+    state.devices.forEach((d, i) => {
+      if (state.mutedDevices.has(d.id)) {
+        d.targetVol = 0;
+        return;
+      }
+      const normalized = maxW > 0 ? weights[i] / maxW : 0;
+      d.targetVol = normalized < 0.02 ? 0 : normalized;
+
+      // Track max volume per group
+      if (d.group) {
+        if (!groupVolumes[d.group] || d.targetVol > groupVolumes[d.group]) {
+          groupVolumes[d.group] = d.targetVol;
+        }
+      }
+    });
+
+    // Apply group volumes: all members of a group get the max volume
+    state.devices.forEach(d => {
+      if (d.group && groupVolumes[d.group] !== undefined) {
+        d.targetVol = groupVolumes[d.group];
+      }
+    });
+  }
+
+  async function sendVolumes() {
+    const toSend = [];
+    for (const d of state.devices) {
+      if (state.mutedDevices.has(d.id)) continue;
+      const target = d.targetVol ?? d.volume ?? 0;
+      const lastSent = state.lastSentVolumes[d.id];
+      if (lastSent === undefined || Math.abs(target - lastSent) > 0.01) {
+        toSend.push({ device_id: d.id, volume: Math.round(target * 1000) / 1000 });
+        state.lastSentVolumes[d.id] = target;
+      }
+    }
+
+    if (toSend.length === 0) return;
+
+    // Prefer WebSocket for lower latency
+    if (socket && socket.connected) {
+      socket.emit("set_volumes_batch", { volumes: toSend });
+    } else {
+      try {
+        await fetch("/api/volume/batch", {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({ volumes: toSend }),
+        });
+      } catch { /* retry next frame */ }
+    }
+  }
+
+  // -----------------------------------------------------------------------
+  // Drawing
+  // -----------------------------------------------------------------------
+  function lerp(a, b, t) { return a + (b - a) * t; }
+
+  function draw() {
+    ctx.clearRect(0, 0, canvas.width, canvas.height);
+
+    // Background rings
+    ctx.beginPath();
+    ctx.arc(CX, CY, RING_RADIUS + 30, 0, Math.PI * 2);
+    ctx.strokeStyle = "rgba(255,255,255,0.04)";
+    ctx.lineWidth = 1;
+    ctx.stroke();
+
+    ctx.beginPath();
+    ctx.arc(CX, CY, RING_RADIUS, 0, Math.PI * 2);
+    ctx.strokeStyle = "rgba(255,255,255,0.08)";
+    ctx.lineWidth = 1;
+    ctx.stroke();
+
+    if (state.devices.length === 0) {
+      ctx.fillStyle = "#555";
+      ctx.font = "16px sans-serif";
+      ctx.textAlign = "center";
+      ctx.textBaseline = "middle";
+      ctx.fillText("No speakers detected", CX, CY);
+      requestAnimationFrame(draw);
+      return;
+    }
+
+    // Group arcs — draw colored arcs connecting grouped devices
+    const drawnGroups = new Set();
+    for (const d of state.devices) {
+      if (d.group && !drawnGroups.has(d.group)) {
+        drawnGroups.add(d.group);
+        const members = state.devices.filter(m => m.group === d.group);
+        if (members.length >= 2) {
+          ctx.beginPath();
+          ctx.strokeStyle = stringToColor(d.group, 0.25);
+          ctx.lineWidth = 3;
+          for (let i = 0; i < members.length; i++) {
+            const m = members[i];
+            if (i === 0) ctx.moveTo(m.x, m.y);
+            else ctx.lineTo(m.x, m.y);
+          }
+          ctx.closePath();
+          ctx.stroke();
+        }
+      }
+    }
+
+    // Connection lines
+    for (const d of state.devices) {
+      const isMuted = state.mutedDevices.has(d.id);
+      if (isMuted) continue;
+      const vol = d.displayVol ?? 0;
+      if (vol < 0.01) continue;
+
+      ctx.beginPath();
+      ctx.moveTo(state.cp.x, state.cp.y);
+      ctx.lineTo(d.x, d.y);
+      ctx.strokeStyle = `rgba(0, 212, 255, ${vol * 0.35})`;
+      ctx.lineWidth = 1 + vol * 2;
+      ctx.stroke();
+    }
+
+    // Device nodes
+    state.devices.forEach((d, idx) => {
+      const isMuted = state.mutedDevices.has(d.id);
+      const target = isMuted ? 0 : (d.targetVol ?? d.volume ?? 0);
+      d.displayVol = lerp(d.displayVol ?? 0, target, 0.15);
+      const vol = d.displayVol;
+      const isFocused = idx === state.focusedDeviceIndex;
+
+      // Audio level ring (outer pulsing ring showing real-time audio)
+      const rawLevel = audioLevels[d.id] || 0;
+      const prevSmooth = audioLevelsSmooth[d.id] || 0;
+      // Fast attack, slow decay for natural-looking meters
+      const smoothed = rawLevel > prevSmooth
+        ? lerp(prevSmooth, rawLevel, 0.4)
+        : lerp(prevSmooth, rawLevel, 0.12);
+      audioLevelsSmooth[d.id] = smoothed;
+      if (smoothed > 0.01 && !isMuted) {
+        const levelRadius = NODE_RADIUS + 4 + smoothed * 18;
+        ctx.beginPath();
+        ctx.arc(d.x, d.y, levelRadius, 0, Math.PI * 2);
+        ctx.strokeStyle = `rgba(29, 185, 84, ${0.3 + smoothed * 0.5})`;
+        ctx.lineWidth = 2 + smoothed * 3;
+        ctx.stroke();
+      }
+
+      // Glow
+      if (vol > 0.01 && !isMuted) {
+        const grad = ctx.createRadialGradient(d.x, d.y, NODE_RADIUS * 0.5, d.x, d.y, NODE_RADIUS * 2 + vol * 20);
+        grad.addColorStop(0, `rgba(0, 212, 255, ${vol * 0.4})`);
+        grad.addColorStop(1, "rgba(0, 212, 255, 0)");
+        ctx.beginPath();
+        ctx.arc(d.x, d.y, NODE_RADIUS * 2 + vol * 20, 0, Math.PI * 2);
+        ctx.fillStyle = grad;
+        ctx.fill();
+      }
+
+      // Node circle
+      ctx.beginPath();
+      ctx.arc(d.x, d.y, NODE_RADIUS, 0, Math.PI * 2);
+      if (isMuted) {
+        ctx.fillStyle = "#2a2a3e";
+        ctx.fill();
+        ctx.strokeStyle = "rgba(255,255,255,0.1)";
+      } else {
+        const brightness = 30 + vol * 40;
+        ctx.fillStyle = `hsl(195, 80%, ${brightness}%)`;
+        ctx.fill();
+        ctx.strokeStyle = vol > 0.01 ? `rgba(0, 212, 255, ${0.4 + vol * 0.6})` : "rgba(255,255,255,0.15)";
+      }
+      ctx.lineWidth = isFocused ? 3 : 2;
+      ctx.stroke();
+
+      // Focus ring
+      if (isFocused) {
+        ctx.beginPath();
+        ctx.arc(d.x, d.y, NODE_RADIUS + 4, 0, Math.PI * 2);
+        ctx.strokeStyle = "#ff8c32";
+        ctx.lineWidth = 2;
+        ctx.stroke();
+      }
+
+      // Text inside node
+      ctx.fillStyle = isMuted ? "#666" : "#fff";
+      ctx.font = "bold 13px sans-serif";
+      ctx.textAlign = "center";
+      ctx.textBaseline = "middle";
+      if (isMuted) {
+        ctx.fillText("MUTE", d.x, d.y);
+      } else {
+        ctx.fillText(`${Math.round(vol * 100)}%`, d.x, d.y);
+      }
+
+      // Device name
+      ctx.fillStyle = isMuted ? "#555" : "#aaa";
+      ctx.font = "11px sans-serif";
+      const name = d.name.length > 20 ? d.name.slice(0, 18) + "..." : d.name;
+      ctx.fillText(name, d.x, d.y + NODE_RADIUS + 14);
+
+      // Group tag
+      if (d.group) {
+        ctx.fillStyle = stringToColor(d.group);
+        ctx.font = "9px sans-serif";
+        ctx.fillText(d.group, d.x, d.y + NODE_RADIUS + 26);
+      }
+    });
+
+    // Control point
+    const cpGrad = ctx.createRadialGradient(state.cp.x, state.cp.y, 2, state.cp.x, state.cp.y, CP_RADIUS);
+    cpGrad.addColorStop(0, "#ffffff");
+    cpGrad.addColorStop(1, "rgba(255, 140, 50, 0.9)");
+    ctx.beginPath();
+    ctx.arc(state.cp.x, state.cp.y, CP_RADIUS, 0, Math.PI * 2);
+    ctx.fillStyle = cpGrad;
+    ctx.fill();
+    ctx.strokeStyle = "#ff8c32";
+    ctx.lineWidth = 2.5;
+    ctx.stroke();
+
+    // Crosshair inside control point
+    ctx.strokeStyle = "rgba(0,0,0,0.3)";
+    ctx.lineWidth = 1;
+    ctx.beginPath();
+    ctx.moveTo(state.cp.x - 5, state.cp.y);
+    ctx.lineTo(state.cp.x + 5, state.cp.y);
+    ctx.moveTo(state.cp.x, state.cp.y - 5);
+    ctx.lineTo(state.cp.x, state.cp.y + 5);
+    ctx.stroke();
+
+    // Curve type label (small, bottom-right of canvas)
+    ctx.fillStyle = "rgba(255,255,255,0.15)";
+    ctx.font = "10px sans-serif";
+    ctx.textAlign = "right";
+    ctx.textBaseline = "bottom";
+    ctx.fillText(state.curveType, canvas.width - 16, canvas.height - 10);
+
+    requestAnimationFrame(draw);
+  }
+
+  function stringToColor(str, alpha) {
+    let hash = 0;
+    for (let i = 0; i < str.length; i++) hash = str.charCodeAt(i) + ((hash << 5) - hash);
+    const h = Math.abs(hash) % 360;
+    if (alpha !== undefined) return `hsla(${h}, 70%, 60%, ${alpha})`;
+    return `hsl(${h}, 70%, 60%)`;
+  }
+
+  // -----------------------------------------------------------------------
+  // Pointer interaction
+  // -----------------------------------------------------------------------
+  function getPointerPos(e) {
+    const rect = canvas.getBoundingClientRect();
+    const scaleX = canvas.width / rect.width;
+    const scaleY = canvas.height / rect.height;
+    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
+    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
+    return { x: (clientX - rect.left) * scaleX, y: (clientY - rect.top) * scaleY };
+  }
+
+  function isNearCP(pos) {
+    const dx = pos.x - state.cp.x;
+    const dy = pos.y - state.cp.y;
+    return dx * dx + dy * dy <= (CP_RADIUS + 10) * (CP_RADIUS + 10);
+  }
+
+  function isNearDevice(pos) {
+    for (let i = 0; i < state.devices.length; i++) {
+      const d = state.devices[i];
+      const dx = pos.x - d.x;
+      const dy = pos.y - d.y;
+      if (dx * dx + dy * dy <= (NODE_RADIUS + 6) * (NODE_RADIUS + 6)) return i;
+    }
+    return -1;
+  }
+
+  function clampToRing(x, y) {
+    const dx = x - CX;
+    const dy = y - CY;
+    const dist = Math.sqrt(dx * dx + dy * dy);
+    const maxDist = RING_RADIUS - 5;
+    if (dist > maxDist) return { x: CX + (dx / dist) * maxDist, y: CY + (dy / dist) * maxDist };
+    return { x, y };
+  }
+
+  function nearestDeviceIndex() {
+    let nearest = -1, minDist = Infinity;
+    state.devices.forEach((d, i) => {
+      const dx = state.cp.x - d.x;
+      const dy = state.cp.y - d.y;
+      const dist = dx * dx + dy * dy;
+      if (dist < minDist) { minDist = dist; nearest = i; }
+    });
+    return nearest;
+  }
+
+  // Mouse events
+  canvas.addEventListener("mousedown", (e) => {
+    const pos = getPointerPos(e);
+
+    // Check for click on device node (toggle mute)
+    const devIdx = isNearDevice(pos);
+    if (devIdx >= 0 && !isNearCP(pos)) {
+      toggleMute(state.devices[devIdx].id);
+      return;
+    }
+
+    if (isNearCP(pos)) {
+      state.isDragging = true;
+      canvas.style.cursor = "grabbing";
+    }
+  });
+
+  canvas.addEventListener("mousemove", (e) => {
+    const pos = getPointerPos(e);
+    if (state.isDragging) {
+      const clamped = clampToRing(pos.x, pos.y);
+      state.cp.x = clamped.x;
+      state.cp.y = clamped.y;
+      computeVolumes();
+    } else {
+      const devIdx = isNearDevice(pos);
+      if (isNearCP(pos)) canvas.style.cursor = "grab";
+      else if (devIdx >= 0) canvas.style.cursor = "pointer";
+      else canvas.style.cursor = "default";
+    }
+  });
+
+  canvas.addEventListener("mouseup", () => {
+    if (state.isDragging) { state.isDragging = false; sendVolumes(); }
+    canvas.style.cursor = "default";
+  });
+
+  canvas.addEventListener("mouseleave", () => {
+    if (state.isDragging) { state.isDragging = false; sendVolumes(); }
+    canvas.style.cursor = "default";
+  });
+
+  // Touch events
+  canvas.addEventListener("touchstart", (e) => {
+    const pos = getPointerPos(e);
+    const devIdx = isNearDevice(pos);
+    if (devIdx >= 0 && !isNearCP(pos)) { toggleMute(state.devices[devIdx].id); e.preventDefault(); return; }
+    if (isNearCP(pos)) { state.isDragging = true; e.preventDefault(); }
+  }, { passive: false });
+
+  canvas.addEventListener("touchmove", (e) => {
+    if (state.isDragging) {
+      e.preventDefault();
+      const pos = getPointerPos(e);
+      const clamped = clampToRing(pos.x, pos.y);
+      state.cp.x = clamped.x;
+      state.cp.y = clamped.y;
+      computeVolumes();
+    }
+  }, { passive: false });
+
+  canvas.addEventListener("touchend", () => {
+    if (state.isDragging) { state.isDragging = false; sendVolumes(); }
+  });
+
+  // -----------------------------------------------------------------------
+  // Keyboard controls
+  // -----------------------------------------------------------------------
+  canvas.addEventListener("keydown", (e) => {
+    const step = e.shiftKey ? ARROW_FINE_STEP : ARROW_STEP;
+    let handled = true;
+
+    switch (e.key) {
+      case "ArrowUp": {
+        const c = clampToRing(state.cp.x, state.cp.y - step);
+        state.cp.x = c.x; state.cp.y = c.y;
+        computeVolumes(); sendVolumes();
+        announcePosition();
+        break;
+      }
+      case "ArrowDown": {
+        const c = clampToRing(state.cp.x, state.cp.y + step);
+        state.cp.x = c.x; state.cp.y = c.y;
+        computeVolumes(); sendVolumes();
+        announcePosition();
+        break;
+      }
+      case "ArrowLeft": {
+        const c = clampToRing(state.cp.x - step, state.cp.y);
+        state.cp.x = c.x; state.cp.y = c.y;
+        computeVolumes(); sendVolumes();
+        announcePosition();
+        break;
+      }
+      case "ArrowRight": {
+        const c = clampToRing(state.cp.x + step, state.cp.y);
+        state.cp.x = c.x; state.cp.y = c.y;
+        computeVolumes(); sendVolumes();
+        announcePosition();
+        break;
+      }
+      case "Home": {
+        state.cp.x = CX; state.cp.y = CY;
+        computeVolumes(); sendVolumes();
+        announce("Control point centered");
+        break;
+      }
+      case "m":
+      case "M": {
+        const ni = nearestDeviceIndex();
+        if (ni >= 0) toggleMute(state.devices[ni].id);
+        break;
+      }
+      case "Tab": {
+        e.preventDefault();
+        if (state.devices.length > 0) {
+          state.focusedDeviceIndex = (state.focusedDeviceIndex + 1) % state.devices.length;
+          const d = state.devices[state.focusedDeviceIndex];
+          const vol = Math.round((d.displayVol ?? 0) * 100);
+          const muted = state.mutedDevices.has(d.id) ? ", muted" : "";
+          announce(`${d.name}, ${vol}%${muted}`);
+        }
+        break;
+      }
+      default: {
+        // Number keys 1-9 for presets
+        const num = parseInt(e.key);
+        if (num >= 1 && num <= 9) {
+          const presets = loadPresets();
+          if (num <= presets.length) {
+            applyPreset(presets[num - 1]);
+          }
+        } else {
+          handled = false;
+        }
+      }
+    }
+
+    if (handled) e.preventDefault();
+  });
+
+  function announcePosition() {
+    const nearest = nearestDeviceIndex();
+    if (nearest >= 0) {
+      const d = state.devices[nearest];
+      const vol = Math.round((d.targetVol ?? 0) * 100);
+      announce(`Nearest: ${d.name} at ${vol}%`);
+    }
+  }
+
+  // -----------------------------------------------------------------------
+  // Mute toggle
+  // -----------------------------------------------------------------------
+  async function toggleMute(deviceId) {
+    const isMuted = state.mutedDevices.has(deviceId);
+    const newMuted = !isMuted;
+
+    if (newMuted) state.mutedDevices.add(deviceId);
+    else state.mutedDevices.delete(deviceId);
+
+    const dev = state.devices.find(d => d.id === deviceId);
+    const name = dev ? dev.name : deviceId;
+    announce(`${name} ${newMuted ? "muted" : "unmuted"}`);
+
+    computeVolumes();
+    sendVolumes();
+    updateStatus();
+
+    try {
+      await fetch("/api/mute", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ device_id: deviceId, muted: newMuted }),
+      });
+    } catch { /* ignore */ }
+  }
+
+  // -----------------------------------------------------------------------
+  // Presets (localStorage)
+  // -----------------------------------------------------------------------
+  const PRESETS_KEY = "bt-mixer-presets";
+
+  function loadPresets() {
+    try {
+      return JSON.parse(localStorage.getItem(PRESETS_KEY)) || [];
+    } catch { return []; }
+  }
+
+  function savePresets(presets) {
+    localStorage.setItem(PRESETS_KEY, JSON.stringify(presets.slice(0, 20)));
+    renderPresetList();
+  }
+
+  function applyPreset(preset) {
+    state.cp.x = preset.x;
+    state.cp.y = preset.y;
+    if (preset.curve) {
+      state.curveType = preset.curve;
+      document.getElementById("selCurve").value = preset.curve;
+    }
+    computeVolumes();
+    sendVolumes();
+    announce(`Loaded preset: ${preset.name}`);
+  }
+
+  function renderPresetList() {
+    const list = document.getElementById("presetList");
+    const presets = loadPresets();
+    list.innerHTML = "";
+    presets.forEach((p, i) => {
+      const li = document.createElement("li");
+      const nameSpan = document.createElement("span");
+      nameSpan.className = "preset-name";
+      nameSpan.textContent = `${i + 1}. ${p.name}`;
+      nameSpan.title = `Load preset "${p.name}" (or press ${i + 1})`;
+      nameSpan.addEventListener("click", () => applyPreset(p));
+
+      const delBtn = document.createElement("span");
+      delBtn.className = "preset-delete";
+      delBtn.textContent = "\u00d7";
+      delBtn.title = "Delete preset";
+      delBtn.addEventListener("click", () => {
+        const updated = loadPresets().filter((_, j) => j !== i);
+        savePresets(updated);
+      });
+
+      li.appendChild(nameSpan);
+      li.appendChild(delBtn);
+      list.appendChild(li);
+    });
+  }
+
+  document.getElementById("btnSavePreset").addEventListener("click", () => {
+    const input = document.getElementById("presetNameInput");
+    const name = input.value.trim();
+    if (!name) return;
+    const presets = loadPresets();
+    presets.push({
+      name,
+      x: state.cp.x,
+      y: state.cp.y,
+      curve: state.curveType,
+    });
+    savePresets(presets);
+    input.value = "";
+    announce(`Saved preset: ${name}`);
+  });
+
+  // -----------------------------------------------------------------------
+  // Crossfade curve selector
+  // -----------------------------------------------------------------------
+  document.getElementById("selCurve").addEventListener("change", (e) => {
+    state.curveType = e.target.value;
+    computeVolumes();
+    sendVolumes();
+    updateStatus();
+    announce(`Crossfade curve: ${state.curveType}`);
+  });
+
+  // -----------------------------------------------------------------------
+  // Center reset button
+  // -----------------------------------------------------------------------
+  document.getElementById("btnCenterReset").addEventListener("click", () => {
+    state.cp.x = CX;
+    state.cp.y = CY;
+    computeVolumes();
+    sendVolumes();
+    announce("Control point centered");
+  });
+
+  // -----------------------------------------------------------------------
+  // Groups
+  // -----------------------------------------------------------------------
+  function renderGroupList() {
+    const list = document.getElementById("groupList");
+    list.innerHTML = "";
+    for (const [name, members] of Object.entries(state.groups)) {
+      const li = document.createElement("li");
+      const nameSpan = document.createElement("span");
+      nameSpan.className = "group-name";
+      nameSpan.textContent = name;
+
+      const membersSpan = document.createElement("span");
+      membersSpan.className = "group-members";
+      const memberNames = members.map(mid => {
+        const dev = state.devices.find(d => d.id === mid);
+        return dev ? dev.name : mid.slice(0, 12) + "...";
+      });
+      membersSpan.textContent = memberNames.join(", ");
+
+      const delBtn = document.createElement("span");
+      delBtn.className = "group-delete";
+      delBtn.textContent = "\u00d7";
+      delBtn.addEventListener("click", async () => {
+        try {
+          await fetch(`/api/groups/${encodeURIComponent(name)}`, { method: "DELETE" });
+        } catch { /* ignore */ }
+      });
+
+      li.appendChild(nameSpan);
+      li.appendChild(membersSpan);
+      li.appendChild(delBtn);
+      list.appendChild(li);
+    }
+  }
+
+  function renderGroupDeviceChecklist() {
+    const list = document.getElementById("groupDeviceChecklist");
+    list.innerHTML = "";
+    state.devices.forEach(d => {
+      const li = document.createElement("li");
+      const cb = document.createElement("input");
+      cb.type = "checkbox";
+      cb.value = d.id;
+      cb.id = "gcb_" + d.id;
+      const label = document.createElement("label");
+      label.htmlFor = cb.id;
+      label.textContent = d.name;
+      li.appendChild(cb);
+      li.appendChild(label);
+      list.appendChild(li);
+    });
+  }
+
+  document.getElementById("btnCreateGroup").addEventListener("click", async () => {
+    const nameInput = document.getElementById("groupNameInput");
+    const name = nameInput.value.trim();
+    if (!name) return;
+
+    const checklist = document.getElementById("groupDeviceChecklist");
+    const checked = Array.from(checklist.querySelectorAll("input:checked")).map(cb => cb.value);
+    if (checked.length < 2) {
+      announce("Select at least 2 devices for a group");
+      return;
+    }
+
+    try {
+      await fetch("/api/groups", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ name, device_ids: checked }),
+      });
+      nameInput.value = "";
+      // Uncheck all
+      checklist.querySelectorAll("input:checked").forEach(cb => cb.checked = false);
+      announce(`Created group: ${name}`);
+    } catch { /* ignore */ }
+  });
+
+  // -----------------------------------------------------------------------
+  // EQ Panel
+  // -----------------------------------------------------------------------
+  function renderEQPanel() {
+    const container = document.getElementById("eqContainer");
+    container.innerHTML = "";
+
+    state.devices.forEach(d => {
+      const section = document.createElement("div");
+      section.className = "eq-device-section";
+
+      const nameDiv = document.createElement("div");
+      nameDiv.className = "eq-name";
+      nameDiv.textContent = d.name;
+      section.appendChild(nameDiv);
+
+      const eq = d.eq || { bass: 0, treble: 0 };
+
+      ["bass", "treble"].forEach(param => {
+        const row = document.createElement("div");
+        row.className = "eq-slider-row";
+
+        const label = document.createElement("label");
+        label.textContent = param.charAt(0).toUpperCase() + param.slice(1);
+
+        const slider = document.createElement("input");
+        slider.type = "range";
+        slider.min = "-100";
+        slider.max = "100";
+        slider.value = String(Math.round(eq[param] * 100));
+        slider.setAttribute("aria-label", `${d.name} ${param}`);
+
+        const valSpan = document.createElement("span");
+        valSpan.className = "eq-val";
+        valSpan.textContent = (eq[param] >= 0 ? "+" : "") + eq[param].toFixed(1);
+
+        slider.addEventListener("input", () => {
+          const val = parseInt(slider.value) / 100;
+          valSpan.textContent = (val >= 0 ? "+" : "") + val.toFixed(1);
+        });
+
+        slider.addEventListener("change", async () => {
+          const val = parseInt(slider.value) / 100;
+          const body = { device_id: d.id };
+          body[param] = val;
+          try {
+            await fetch("/api/eq", {
+              method: "POST",
+              headers: { "Content-Type": "application/json" },
+              body: JSON.stringify(body),
+            });
+          } catch { /* ignore */ }
+        });
+
+        row.appendChild(label);
+        row.appendChild(slider);
+        row.appendChild(valSpan);
+        section.appendChild(row);
+      });
+
+      container.appendChild(section);
+    });
+  }
+
+  // -----------------------------------------------------------------------
+  // Refresh button
+  // -----------------------------------------------------------------------
+  document.getElementById("btnRefresh").addEventListener("click", async () => {
+    try {
+      if (socket && socket.connected) {
+        socket.emit("request_refresh");
+      } else {
+        const res = await fetch("/api/refresh", { method: "POST" });
+        if (res.ok) await fetchDevices();
+      }
+    } catch { /* ignore */ }
+  });
+
+  // -----------------------------------------------------------------------
+  // Audio Level & Spotify WebSocket listeners
+  // -----------------------------------------------------------------------
+  if (socket) {
+    socket.on("audio_levels", (levels) => {
+      for (const [id, level] of Object.entries(levels)) {
+        audioLevels[id] = level;
+      }
+    });
+
+    socket.on("spotify_now_playing", (np) => {
+      updateSpotifyUI(np);
+    });
+  }
+
+  // -----------------------------------------------------------------------
+  // Spotify UI
+  // -----------------------------------------------------------------------
+  const spotifyBar = document.getElementById("spotifyBar");
+  const spotifyConnect = document.getElementById("spotifyConnect");
+  const spotifyTrack = document.getElementById("spotifyTrack");
+  const spotifyArtist = document.getElementById("spotifyArtist");
+  const spotifyArt = document.getElementById("spotifyArt");
+  const spotifyProgress = document.getElementById("spotifyProgress");
+  const btnSpotifyPlay = document.getElementById("btnSpotifyPlay");
+  let spotifyPlaying = false;
+  let spotifyProgressMs = 0;
+  let spotifyDurationMs = 0;
+  let spotifyLastUpdateTs = 0;
+
+  function updateSpotifyUI(np) {
+    if (!np || !np.track) {
+      spotifyBar.classList.add("hidden");
+      spotifyConnect.classList.remove("hidden");
+      return;
+    }
+    spotifyBar.classList.remove("hidden");
+    spotifyConnect.classList.add("hidden");
+
+    spotifyTrack.textContent = np.track || "Unknown";
+    spotifyArtist.textContent = np.artist || "";
+    spotifyPlaying = np.is_playing;
+    btnSpotifyPlay.innerHTML = np.is_playing ? "&#9646;&#9646;" : "&#9654;";
+    btnSpotifyPlay.title = np.is_playing ? "Pause" : "Play";
+
+    if (np.album_art) {
+      spotifyArt.src = np.album_art;
+      spotifyArt.style.display = "";
+    } else {
+      spotifyArt.style.display = "none";
+    }
+
+    // Store for local interpolation
+    spotifyProgressMs = np.progress_ms || 0;
+    spotifyDurationMs = np.duration_ms || 0;
+    spotifyLastUpdateTs = Date.now();
+
+    if (spotifyDurationMs > 0) {
+      const pct = Math.min(100, (spotifyProgressMs / spotifyDurationMs) * 100);
+      spotifyProgress.style.width = pct + "%";
+    }
+  }
+
+  // Interpolate Spotify progress bar locally (smooth between 3s server updates)
+  setInterval(() => {
+    if (!spotifyPlaying || spotifyDurationMs <= 0) return;
+    const elapsed = Date.now() - spotifyLastUpdateTs;
+    const currentMs = Math.min(spotifyDurationMs, spotifyProgressMs + elapsed);
+    const pct = Math.min(100, (currentMs / spotifyDurationMs) * 100);
+    spotifyProgress.style.width = pct + "%";
+  }, 500);
+
+  // Spotify connect button
+  document.getElementById("btnSpotifyConnect").addEventListener("click", () => {
+    const clientId = prompt("Enter your Spotify Client ID:\n(Create one at https://developer.spotify.com/dashboard)");
+    if (clientId && clientId.trim()) {
+      window.location.href = "/api/spotify/login?client_id=" + encodeURIComponent(clientId.trim());
+    }
+  });
+
+  // Spotify playback controls
+  btnSpotifyPlay.addEventListener("click", async () => {
+    const endpoint = spotifyPlaying ? "/api/spotify/pause" : "/api/spotify/play";
+    try { await fetch(endpoint, { method: "POST" }); } catch { /* ignore */ }
+  });
+
+  document.getElementById("btnSpotifyPrev").addEventListener("click", async () => {
+    try { await fetch("/api/spotify/previous", { method: "POST" }); } catch { /* ignore */ }
+  });
+
+  document.getElementById("btnSpotifyNext").addEventListener("click", async () => {
+    try { await fetch("/api/spotify/next", { method: "POST" }); } catch { /* ignore */ }
+  });
+
+  document.getElementById("btnSpotifyDisconnect").addEventListener("click", async () => {
+    try { await fetch("/api/spotify/disconnect", { method: "POST" }); } catch { /* ignore */ }
+    spotifyBar.classList.add("hidden");
+    spotifyConnect.classList.remove("hidden");
+  });
+
+  // Check Spotify status on load and poll as HTTP fallback
+  function fetchSpotifyStatus() {
+    fetch("/api/spotify/status").then(r => r.json()).then(data => {
+      if (data.connected && data.now_playing) {
+        updateSpotifyUI(data.now_playing);
+      }
+    }).catch(() => {});
+  }
+  fetchSpotifyStatus();
+  setInterval(() => {
+    if (!socket || !socket.connected) fetchSpotifyStatus();
+  }, 5000);
+
+  // -----------------------------------------------------------------------
+  // Main loop
+  // -----------------------------------------------------------------------
+
+  // Volume updates at ~30fps while dragging
+  setInterval(() => { if (state.isDragging) sendVolumes(); }, 33);
+
+  // HTTP polling fallback (only if WebSocket is not connected)
+  fetchDevices();
+  setInterval(() => {
+    if (!socket || !socket.connected) fetchDevices();
+  }, 5000);
+
+  // Fetch groups on load
+  fetch("/api/groups").then(r => r.json()).then(g => {
+    state.groups = g || {};
+    renderGroupList();
+  }).catch(() => {});
+
+  // Init UI
+  renderPresetList();
+  requestAnimationFrame(draw);
+})();
+</script>
+</body>
+</html>
