+<body>
+
+<h1>Bluetooth Crossfade Mixer</h1>
+<p class="subtitle">Drag the control point or use arrow keys to blend volume between speakers</p>
+
+<!-- Live region for screen readers -->
+<div id="ariaLive" class="sr-only" aria-live="polite" aria-atomic="true"></div>
+
+<canvas id="mixer" width="500" height="500" tabindex="0" role="application"
+  aria-label="Radial crossfade mixer. Use arrow keys to move the control point between speakers."></canvas>
+
+<div class="toolbar">
